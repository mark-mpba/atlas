{
  "name": "mpba/laravel-modules",
  "description": "Laravel Module management",
  "version":"9.0.1",
  "keywords": [
    "modules",
    "laravel",
    "mpba",
    "module",
    "rad"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Mark Gregory",
      "email": "mark.gregory@mpba.co.uk",
      "homepage": "https://mpba.co.uk",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.3",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5",
    "mockery/mockery": "~1.0",
    "orchestra/testbench": "^6.0",
    "friendsofphp/php-cs-fixer": "^2.16",
    "laravel/framework": "^8.0",
    "spatie/phpunit-snapshot-assertions": "^2.1.0",
    "phpstan/phpstan": "^0.12.14"
  },
  "autoload": {
    "psr-4": {
      "mpba\\Modules\\": "src"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "mpba\\Modules\\Tests\\": "tests",
      "Modules\\Recipe\\": "tests/stubs/valid/Recipe"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "mpba\\Modules\\LaravelModulesServiceProvider"
      ],
      "aliases": {
        "Module": "mpba\\Modules\\Facades\\Module"
      }
    },
    "branch-alias": {
      "dev-master": "8.0-dev"
    }
  },
  "scripts": {
    "update-snapshots": "./vendor/bin/phpunit --no-coverage -d --update-snapshots",
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --debug --coverage-html coverage",
    "pcf": "vendor/bin/php-cs-fixer fix --verbose"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
