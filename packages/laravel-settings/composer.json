{
  "name": "mpba/laravel-settings",
  "description": "Store key value pair in database as settings",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "mpba",
    "laravel",
    "database settings",
    "db settings",
    "eloquent"
  ],
  "authors": [
    {
      "name": "Mark Gregpory",
      "email": "mark.gregory@mpba.co.uk"
    }
  ],
  "require": {
    "php": "^7.3|^8.0|^8.1|^8.2",
    "laravel/framework": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "4.*|5.*|6.*|^8.0|^9.0",
    "mockery/mockery": "^0.9.4 || ~1.0",
    "phpunit/phpunit": "^8.5|^9.5.10|^10.5"
  },
  "autoload": {
    "classmap": [
      "src/migrations"
    ],
    "psr-4": {
      "mpba\\Settings\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "mpba\\Settings\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "mpba\\Settings\\SettingsServiceProvider"
      ],
      "aliases": {
        "Settings": "mpba\\Settings\\Facade"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
